# =============================================================================
# GFAST-MPTS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public URL and anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — SERVER ONLY, never expose to the browser.
# Used only in /app/api routes via lib/supabase/admin.ts (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── App ─────────────────────────────────────────────────────────────────────
# The public URL of this app (no trailing slash).
# Used for Supabase auth redirect URLs and invite emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# The origin allowed to call your API (no trailing slash).
# In production, set this to your deployed domain (e.g. https://gcfast.vercel.app).
# The app will throw a startup error in production if this is missing.
ALLOWED_ORIGIN=http://localhost:3000

# =============================================================================
# How to find your Supabase values:
#   1. Go to https://supabase.com/dashboard
#   2. Select your project
#   3. Settings → API
#   4. Copy "Project URL"         → NEXT_PUBLIC_SUPABASE_URL
#   5. Copy "anon public" key     → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   6. Copy "service_role" key    → SUPABASE_SERVICE_ROLE_KEY (keep secret!)
# =============================================================================
